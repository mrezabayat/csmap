{
  "name": "computer-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run gen:progress-meta && astro dev",
    "start": "npm run dev",
    "build": "npm run gen:progress-meta && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run gen:progress-meta && astro check",
    "gen:progress-meta": "node scripts/gen-progress-meta.mjs",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "lint:content": "node scripts/lint-content.mjs",
    "audit:orphans": "node scripts/find-orphans.mjs",
    "audit:importance": "node scripts/audit-importance.mjs",
    "audit:taxonomy": "node scripts/audit-taxonomy.mjs",
    "new:topic": "node scripts/new-topic.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@pagefind/default-ui": "^1.5.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "~4.1",
    "@xyflow/react": "^12.11.0",
    "astro": "^5.18.2",
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.45.2",
    "mermaid": "^11.15.0",
    "pagefind": "^1.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "tailwindcss": "~4.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3"
  }
}
