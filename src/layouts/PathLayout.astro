---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import LearningProgressRoadmap from "~/components/LearningProgressRoadmap";
import { loadGraph, topicUrl } from "~/lib/graph";
import { normalisePathTopics } from "~/lib/paths";
import { sumPathReadingTime } from "~/lib/reading-time";
import { editUrl } from "~/site.config";

interface Props {
  path: CollectionEntry<"paths">;
}

const { path } = Astro.props;
const { title, summary, audience, topics, updated } = path.data;
const graph = await loadGraph();
const editHref = path.filePath ? editUrl(path.filePath) : null;

const normalised = normalisePathTopics(topics);
const orderedItems = normalised
  .map((n) => {
    const entry = graph.topicsById.get(n.id);
    return entry ? { ...n, entry } : null;
  })
  .filter((item): item is NonNullable<typeof item> => Boolean(item));

const totalCount = orderedItems.length;
const requiredCount = orderedItems.filter((i) => !i.optional).length;
const optionalCount = totalCount - requiredCount;

// Reading-time totals (required vs optional, in minutes).
const { requiredMinutes, optionalMinutes } = sumPathReadingTime(
  orderedItems.filter((i) => !i.optional).map((i) => i.entry),
  orderedItems.filter((i) => i.optional).map((i) => i.entry),
);

// Level distribution across all topics (optional included for transparency).
const levelOrder = ["beginner", "intermediate", "advanced"] as const;
const levelCounts: Record<(typeof levelOrder)[number], number> = {
  beginner: 0,
  intermediate: 0,
  advanced: 0,
};
for (const item of orderedItems) {
  const lvl = item.entry.data.level;
  if (lvl in levelCounts) levelCounts[lvl]++;
}
const levelSummary = levelOrder
  .filter((l) => levelCounts[l] > 0)
  .map((l) => `${levelCounts[l]} ${l}`)
  .join(" · ");

const updatedLabel = updated.toISOString().slice(0, 10);
const roadmapTopics = orderedItems.map((i) => ({
  id: i.id,
  title: i.entry.data.title,
  summary: i.entry.data.summary,
  href: topicUrl(i.id),
  optional: i.optional,
  section: i.section,
  // Fog of War (G3): in-path prerequisites drive lock state, filtered client-side.
  prerequisites: graph.relationsById.get(i.id)?.prerequisites ?? [],
}));
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-3xl px-4 py-8">
    <nav class="text-xs text-[var(--color-atlas-muted)]" aria-label="Breadcrumb">
      <a href="/" class="no-underline hover:underline">Atlas</a>
      <span aria-hidden="true"> / </span>
      <a href="/paths" class="no-underline hover:underline">Paths</a>
    </nav>

    <header class="mt-2">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-atlas-ink)]"
      >
        {title}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span
          class="inline-flex items-center rounded-full border border-[var(--color-atlas-line)] bg-[var(--color-atlas-surface)] px-2 py-0.5 text-xs font-medium text-[var(--color-atlas-muted)]"
        >
          For {audience}s
        </span>
        <span class="text-xs text-[var(--color-atlas-muted)]">
          {totalCount} topics
          {optionalCount > 0 && ` (${requiredCount} required · ${optionalCount} optional)`}
          · updated {updatedLabel}
        </span>
      </div>
      <p class="mt-4 text-lg text-[var(--color-atlas-ink)]">
        {summary}
      </p>
      <dl
        class="mt-4 flex flex-wrap items-baseline gap-x-6 gap-y-1 text-sm text-[var(--color-atlas-muted)]"
      >
        <div class="flex items-baseline gap-1">
          <dt class="text-xs uppercase tracking-wide">Reading time</dt>
          <dd class="text-[var(--color-atlas-ink)]">
            ~{requiredMinutes} min
            {optionalMinutes > 0 && (
              <span class="text-[var(--color-atlas-muted)]"> (+{optionalMinutes} min optional)</span>
            )}
          </dd>
        </div>
        {levelSummary && (
          <div class="flex items-baseline gap-1">
            <dt class="text-xs uppercase tracking-wide">Level mix</dt>
            <dd class="text-[var(--color-atlas-ink)]">{levelSummary}</dd>
          </div>
        )}
      </dl>
    </header>

    <div class="prose prose-slate dark:prose-invert mt-6 max-w-none">
      <slot />
    </div>

    {editHref && (
      <p class="mt-4 text-sm">
        <a
          href={editHref}
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline hover:underline text-[var(--color-atlas-muted)]"
        >
          Edit this path on GitHub
        </a>
      </p>
    )}

    <LearningProgressRoadmap
      pathId={path.id}
      topics={roadmapTopics}
      client:load
    />
  </article>
</BaseLayout>
